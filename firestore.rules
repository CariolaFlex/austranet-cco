rules_version = '2';

// ============================================================
// Austranet CCO — Reglas de Seguridad Firestore
// Versión: 3.0 (pre-MVP — M4 y M5 cubiertos, fallback seguro)
// Última actualización: 2026-03-06
//
// POLÍTICA:
//   - Toda lectura requiere autenticación.
//   - Toda escritura requiere autenticación como mínimo.
//   - Colecciones de administración exigen rol admin/superadmin.
//   - El fallback bloquea writes de colecciones no listadas.
//
// VERIFICACIÓN DE ROL:
//   Los roles se almacenan en /usuarios/{uid}.data.rol (no en custom claims).
//   La función isAdmin() los consulta con get() — 1 read extra por operación write.
//
// COLECCIONES:
//   M1: usuarios, entidades, glosario, historial
//   M2: proyectos (+ subcols: historial, lineas_base, snapshots_evm),
//       repositorios_configuracion
//   M3: srs, requerimientos, sesiones_entrevista, escenarios,
//       casos_prueba, terminos_dominio_srs
//   M4: tareas (top-level)
//   M5: apus, catalogo_insumos
//   T:  notificaciones, auditoria, configuracion, configuracion_dashboard
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------
    // Funciones auxiliares
    // --------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica rol admin o superadmin consultando /usuarios/{uid}.
    // El documento debe existir; si no existe, devuelve false (no lanza error).
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol
             in ['admin', 'superadmin'];
    }

    // --------------------------------------------------------
    // MÓDULO 0 — Usuarios
    // --------------------------------------------------------
    match /usuarios/{userId} {
      // Todos los usuarios autenticados pueden leer (panel admin, asignación de roles).
      allow read: if isAuthenticated();
      // Solo el propio usuario puede escribir su perfil.
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --------------------------------------------------------
    // MÓDULO 1 — Entidades (con subcolecciones)
    // --------------------------------------------------------
    match /entidades/{entidadId} {
      allow read, write: if isAuthenticated();

      match /glosario/{terminoId} {
        allow read, write: if isAuthenticated();
      }

      match /historial/{entradaId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false; // Inmutable (M1-06)
      }
    }

    // --------------------------------------------------------
    // MÓDULO 2 — Proyectos (con subcolecciones)
    // --------------------------------------------------------
    match /proyectos/{proyectoId} {
      allow read, write: if isAuthenticated();

      match /historial/{entradaId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false; // Inmutable (M2-04)
      }

      // M4 — Líneas base de planificación (subcol de proyecto)
      match /lineas_base/{lineaId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // M4 — Snapshots EVM semanales (subcol de proyecto, upsert por fecha)
      match /snapshots_evm/{snapshotId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    match /repositorios_configuracion/{configId} {
      allow read, write: if isAuthenticated();
    }

    // --------------------------------------------------------
    // MÓDULO 3 — Alcance / SRS
    // --------------------------------------------------------
    match /srs/{srsId} {
      allow read, write: if isAuthenticated();
    }

    match /requerimientos/{reqId} {
      allow read, write: if isAuthenticated();
      allow delete: if false; // Soft-delete (M3-09)
    }

    match /sesiones_entrevista/{sesionId} {
      allow read, write: if isAuthenticated();
    }

    match /escenarios/{escenarioId} {
      allow read, write: if isAuthenticated();
    }

    match /casos_prueba/{casoId} {
      allow read, write: if isAuthenticated();
    }

    match /terminos_dominio_srs/{terminoId} {
      allow read, write: if isAuthenticated();
    }

    // --------------------------------------------------------
    // MÓDULO 4 — Tareas (top-level, FK proyectoId)
    // --------------------------------------------------------
    match /tareas/{tareaId} {
      // Cualquier usuario autenticado puede leer y escribir tareas.
      // La verificación de pertenencia al proyecto se hace en la capa de servicio.
      allow read, write: if isAuthenticated();
    }

    // --------------------------------------------------------
    // MÓDULO 5 — APU (Análisis de Precios Unitarios)
    // --------------------------------------------------------
    match /apus/{apuId} {
      // Cualquier usuario autenticado puede leer y escribir APUs.
      // La verificación de pertenencia al proyecto se hace en la capa de servicio.
      allow read, write: if isAuthenticated();
    }

    // Catálogo global de insumos — write restringido a admin/superadmin
    match /catalogo_insumos/{insumoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --------------------------------------------------------
    // T-02 — Notificaciones
    // --------------------------------------------------------
    match /notificaciones/{docId} {
      // resource == null cubre queries de colección (Firestore no evalúa
      // resource.data en ese contexto). En lectura de documento individual
      // se verifica que el uid esté en destinatarios.
      allow read: if isAuthenticated()
        && (resource == null || request.auth.uid in resource.data.destinatarios);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (resource == null || request.auth.uid in resource.data.destinatarios);
      allow delete: if false;
    }

    // --------------------------------------------------------
    // T-03 — Auditoría (append-only, inmutable)
    // --------------------------------------------------------
    match /auditoria/{docId} {
      // Todos los usuarios autenticados pueden leer logs de auditoría.
      allow read: if isAuthenticated();
      // Cualquier usuario autenticado puede crear entradas (desde servicios).
      allow create: if isAuthenticated();
      // Nunca modificar ni eliminar — inmutabilidad garantizada por reglas.
      allow update, delete: if false;
    }

    // --------------------------------------------------------
    // T-06 — Configuración del sistema — write solo admin/superadmin
    // --------------------------------------------------------
    match /configuracion/{docId} {
      // Todos los usuarios autenticados pueden leer (modo mantenimiento, versión, etc.)
      allow read: if isAuthenticated();
      // Solo admin/superadmin pueden modificar la configuración.
      allow write: if isAdmin();
    }

    // --------------------------------------------------------
    // T-05 — Configuración del dashboard (personal por usuario)
    // --------------------------------------------------------
    match /configuracion_dashboard/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // --------------------------------------------------------
    // FALLBACK — read permitido para autenticados; write bloqueado.
    // Toda colección nueva DEBE tener regla explícita antes de producción.
    // --------------------------------------------------------
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
